#!/bin/sh
# XBPS wrapper script, inspired by xtools.

set -eu

PKG_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/pkg"
PKG_XBPS_MIRROR="${PKG_XBPS_MIRROR:-https://repo-default.voidlinux.org/current}"
PKG_LOCATE_REPO="${PKG_XBPS_MIRROR%/current}/xlocate/xlocate.git"
PKG_LOCATE_CACHE="$PKG_CACHE/locate"

# shellcheck disable=SC2015
sudocmd="$([ -f /etc/doas.conf ] && command -v doas 2>/dev/null || command -v sudo 2>/dev/null)"

pkg_locate_sync() {
	[ -d "$PKG_LOCATE_CACHE" ] || {
		[ -n "${PKG_LOCATE_CACHE%/*}" ] && mkdir -p "${PKG_LOCATE_CACHE%/*}"
		git clone --bare "$PKG_LOCATE_REPO" "$PKG_LOCATE_CACHE"
	}
	git -C "$PKG_LOCATE_CACHE" fetch -u -f "$PKG_LOCATE_REPO" master:master
}

pkg_locate() {
	[ -d "$PKG_LOCATE_CACHE" ] || pkg_locate_sync
	[ -f "$PKG_LOCATE_CACHE/FETCH_HEAD" ] &&
		base="$PKG_LOCATE_CACHE/FETCH_HEAD"
	[ -f "$PKG_LOCATE_CACHE/refs/heads/master" ] &&
		base="$PKG_LOCATE_CACHE/refs/heads/master"
	[ -z "$base" ] ||
		find /var/db/xbps/ -name "*repodata" -newer "$base" |
		grep -q . &&
		echo "$(basename "$0"): database outdated, update with -s." >&2
	git -c grep.lineNumber=false -c grep.column=false --git-dir="$PKG_LOCATE_CACHE" grep "$@" @ |
		sed "s/^@://" |
		column -t -s ":" -l 2 |
		grep .
}

pkg_bootstrap() {
	chroot="${1:-}"
	[ -n "$chroot" ] || {
		echo "$(basename "$0"): bootstrap: missing chroot argument" >&2
		exit 1
	}
	shift
	umask 0022
	[ -d "$chroot" ] || $sudocmd mkdir -p "$chroot"
	for dir in bin dev etc usr; do
		[ -d "$chroot/$dir" ] && {
			echo "directory contains /$dir, bailing out" >&2
			exit 1
		}
	done
	$sudocmd chown root:root "$chroot"
	$sudocmd chmod 0755 "$chroot"
	$sudocmd mkdir -p "$chroot/boot" "$chroot/dev"
	$sudocmd mkdir -p -m 0555 "$chroot/proc" "$chroot/sys"
	[ -d /var/db/xbps/keys ] && {
		$sudocmd mkdir -p "$chroot/var/db/xbps/keys"
		$sudocmd cp -a /var/db/xbps/keys/* "$chroot/var/db/xbps/keys"
	}
	$sudocmd xbps-install \
		-R "$PKG_XBPS_MIRROR" \
		-R "$PKG_XBPS_MIRROR/musl" \
		-R "$PKG_XBPS_MIRROR/aarch64" \
		-S \
		-r "$chroot" \
		"${@:-base-system}"
}

pkg_update() {
	$sudocmd xbps-install -Sy &&
		$sudocmd xbps-install -uy xbps &&
		$sudocmd xbps-install -uy
	command -v flatpak >/dev/null 2>&1 &&
		flatpak update -y
	# shellcheck disable=SC2086
	command -v makewhatis >/dev/null 2>&1 && {
		man -w | tr -d "\n" | xargs -d ":" $sudocmd makewhatis
	}
	pkg_locate_sync
}

pkg_clean() {
	$sudocmd xbps-remove -Ooy
	command -v vkpurge >/dev/null 2>&1 &&
		$sudocmd vkpurge rm all
}

pkg_search() {
	res="$(xbps-query -Rs --regex "$@")"
	[ $# -eq 1 ] && [ "$(echo "$res" | wc -l)" -eq 1 ] && {
		pkg="$(echo "$res" | cut -d " " -f 2)"
		xbps-query -R "$pkg"
		exit 0
	}
	echo "$res"
}

cmd="${1:-}"
[ $# -gt 0 ] && shift
case "$cmd" in
i | install)
	$sudocmd xbps-install -S "$@"
	;;
u | update)
	case "${1:-}" in
	-a | -all | --all)
		pkg_update
		;;
	*)
		$sudocmd xbps-install -Su "$@"
		;;
	esac
	;;
r | rm | remove)
	$sudocmd xbps-remove -R "$@"
	;;
q | query)
	xbps-query -R "$@"
	;;
s | search)
	xbps-query -Rs --regex "$@"
	;;
l | locate)
	command -v git >/dev/null 2>&1 || {
		echo "$(basename "$0"): git: command not found" >&2
		exit 1
	}
	case "${1:-}" in
	-s | -S)
		pkg_locate_sync
		;;
	*)
		pkg_locate "$@"
		;;
	esac
	;;
bootstrap | voidstrap)
	pkg_bootstrap "$@"
	;;
clean)
	pkg_clean
	;;
*)
	pkg_search "$cmd" "$@"
	;;
esac
