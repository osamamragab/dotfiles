#!/bin/sh

set -eu

export MENU_PROMPT="${MENU_PROMPT:-Menu}"

MENUS_DIR="${MENUS_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/menus}"

menu="${1:-$(
	printf "ó°€» Apps\nï„œ Input Handler\nï‡š Recent Files\nîµ» Clipboard History\nïƒ³ Notifications\nï€® Bookmarks\nó°ž… Emojis\nï‡» Color Picker\nï‚„ Passwords\nïƒ„ Screenshot\nó°»ƒ Screen Recording\nïƒ§ Power Profiles\nó°¹‘ Display Profiles\nï€‘ System Actions" |
		menu slug
)}" || exit 1
[ $# -gt 0 ] && shift

[ -x "$MENUS_DIR/$menu" ] || {
	echo "$(basename "$0"): invalid menu: $menu" >&2
	exit 1
}

MENU_PROMPT="" exec "$MENUS_DIR/$menu" "$@"
