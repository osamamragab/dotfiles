#!/bin/sh

set -eu

app="$(basename "$0")"

export MENU_PROMPT="${MENU_PROMPT:-$app}"
export PASSWORD_STORE_DIR="${PASSWORD_STORE_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/password-store}"

sel="$(
	find "$PASSWORD_STORE_DIR" -type f -name "*.gpg" -printf "%P\n" |
		sed 's/\.gpg$//' |
		menu
)" || exit 1
content="$(pass "$sel")" || {
	ec=$?
	echo "$app: pass command failed" >&2
	notify-send -a "$app" -u critical error "pass command failed"
	exit $ec
}
field="$(
	echo "$content" |
		sed "1s/.*/password/;s/otpauth:\/\/.*/otp/;s/^\([^:]*\)\s*:\s*.*/\1/" |
		menu
)" || exit $?
case "$field" in
password) pass="$(echo "$content" | sed 1q)" ;;
otp) pass="$(pass otp code "$sel")" ;;
*) pass="$(echo "$content" | sed -n "s/$field\s\+\?:\s\+\?\(.*\)/\1/p")" ;;
esac

echo "$pass" | wl-copy --sensitive --type text/plain --foreground --trim-newline
notify-send -a "$app" "$sel" "$field copied to clipboard"
