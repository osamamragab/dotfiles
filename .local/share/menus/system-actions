#!/bin/sh

set -eu

export MENU_PROMPT="${MENU_PROMPT:-System Actions}"

sel="${1:-$(printf "’ĆŻ Lock\n’éŗ Exit\n’åå Suspend\n’éĀ Hibernate\n’ŗ▒ Reboot\n’Ćæ Power Off" | menu slug)}" || exit 1
case "$sel" in
lock)
	loginctl -i lock-session
	;;
exit)
	mmsg -q
	;;
suspend)
	loginctl -i suspend
	;;
hibernate)
	loginctl -i hibernate
	;;
reboot)
	loginctl -i reboot
	;;
power-off)
	loginctl -i poweroff
	;;
*)
	echo "$(basename "$0"): invalid command: $sel" >&2
	exit 1
	;;
esac
